{
  "name": "glitchjs-proxy",
  "main": "GlitchJSProxy.js", // Ensure this points to your worker script
  "compatibility_date": "2024-03-04",
  "observability": {
    "enabled": true
  },
  /*
   * Secrets like PROXY_SECRET are NOT added here. 
   * They are managed via the dashboard or 'wrangler secret put'.
   */
  "vars": {
    "ENVIRONMENT": "production"
  }
}
